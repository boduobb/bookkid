/* pages/profile/profile.wxss */

.page {
  min-height: 100vh;
  background: #FFFBF0;
  padding-bottom: 120rpx;
}

/* 头部 */
.header {
  position: relative;
  padding-bottom: 40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(180deg, #FDF2F8 0%, #FFFBF0 100%);
  border-radius: 0 0 60rpx 60rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  padding: 60rpx 32rpx 0;
}

/* 用户信息 */
.user-section {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar-wrapper {
  position: relative;
  margin-right: 28rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #FFE8A3 0%, #FFD76E 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 199, 48, 0.3);
}

.avatar-emoji {
  font-size: 72rpx;
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.edit-icon {
  font-size: 24rpx;
  margin-left: 12rpx;
  opacity: 0.6;
}

.user-level {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.level-badge {
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #FFD76E 0%, #FFC730 100%);
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.level-bar {
  flex: 1;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 6rpx;
  overflow: hidden;
}

.level-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFD76E 0%, #FFC730 100%);
  border-radius: 6rpx;
}

.level-text {
  font-size: 20rpx;
  color: #9CA3AF;
  flex-shrink: 0;
}

/* 统计行 */
.stats-row {
  display: flex;
  gap: 16rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.stat-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* 内容区 */
.content {
  padding: 0 32rpx;
  margin-top: -20rpx;
  position: relative;
  z-index: 2;
}

.section-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 24rpx;
}

.card-header .card-title {
  margin-bottom: 0;
}

.card-subtitle {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 勋章网格 */
.badges-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -12rpx;
}

.badge-item {
  width: 25%;
  padding: 12rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.badge-icon {
  width: 88rpx;
  height: 88rpx;
  background: #F9FAFB;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.badge-item.unlocked .badge-icon {
  background: linear-gradient(135deg, #FFFBEB 0%, #FEF3C7 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 199, 48, 0.3);
}

.badge-item.locked .badge-icon {
  filter: grayscale(100%);
  opacity: 0.4;
}

.badge-name {
  font-size: 22rpx;
  color: #9CA3AF;
  text-align: center;
}

.badge-item.unlocked .badge-name {
  color: #4B5563;
}

/* 衣橱 */
.wardrobe-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -12rpx;
}

.wardrobe-item {
  width: 33.333%;
  padding: 12rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wardrobe-icon {
  width: 100rpx;
  height: 100rpx;
  background: #F0F9FF;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.wardrobe-item.owned .wardrobe-icon {
  background: #F0FFF7;
}

.wardrobe-name {
  font-size: 22rpx;
  color: #4B5563;
  margin-bottom: 4rpx;
}

.wardrobe-price {
  font-size: 20rpx;
  color: #F59E0B;
}

.wardrobe-owned {
  font-size: 20rpx;
  color: #10B981;
}

/* 设置列表 */
.settings-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #F3F4F6;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  display: flex;
  align-items: center;
}

.setting-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.setting-name {
  font-size: 28rpx;
  color: #1F2937;
}

.setting-arrow {
  font-size: 32rpx;
  color: #9CA3AF;
}

/* 菜单列表 */
.menu-list {
  margin: -8rpx 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #F3F4F6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #1F2937;
}

.menu-arrow {
  font-size: 32rpx;
  color: #D1D5DB;
}

/* 底部文字 */
.footer-text {
  text-align: center;
  font-size: 24rpx;
  color: #D1D5DB;
  padding: 40rpx 0 20rpx;
}
