/* pages/records/records.wxss */

.page {
  min-height: 100vh;
  background: #FFFBF0;
}

/* 头部 */
.header {
  position: relative;
  padding-top: 60rpx;
  padding-bottom: 40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: linear-gradient(180deg, #E0F2FE 0%, #FFFBF0 100%);
  border-radius: 0 0 60rpx 60rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  padding: 0 32rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: #6B7280;
}

/* Tab切换 */
.tabs {
  display: flex;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  background: #fff;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #6B7280;
  transition: all 0.3s;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.tab-item.active {
  background: linear-gradient(135deg, #FFD76E 0%, #FFC730 100%);
  color: #fff;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(255, 199, 48, 0.4);
}

/* 内容区 */
.content {
  padding: 0 32rpx 120rpx;
}

.tab-content {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 统计卡片 */
.stats-card {
  display: flex;
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #9CA3AF;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: #F3F4F6;
  align-self: center;
}

/* 日历卡片 */
.calendar-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.calendar-nav {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F3F4F6;
  border-radius: 50%;
  font-size: 36rpx;
  color: #6B7280;
}

.calendar-month {
  font-size: 32rpx;
  font-weight: bold;
  color: #1F2937;
}

.weekdays {
  display: flex;
  margin-bottom: 16rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #9CA3AF;
  padding: 12rpx 0;
}

.calendar-days {
  display: flex;
  flex-wrap: wrap;
}

.calendar-day {
  width: 14.285%;
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.calendar-day.empty .day-number {
  color: transparent;
}

.day-number {
  font-size: 26rpx;
  color: #4B5563;
  margin-bottom: 6rpx;
}

.calendar-day.marked .day-number {
  color: #FF9F43;
  font-weight: bold;
}

.calendar-day.today .day-number {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: linear-gradient(135deg, #FFD76E 0%, #FFC730 100%);
  color: #fff;
  border-radius: 50%;
  margin-bottom: 0;
}

.day-dot {
  width: 10rpx;
  height: 10rpx;
  background: #FFC730;
  border-radius: 50%;
}

.calendar-day.today .day-dot {
  display: none;
}

.calendar-legend {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #F3F4F6;
}

.legend-item {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #6B7280;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.legend-dot.marked {
  background: #FFC730;
}

.legend-dot.today {
  background: linear-gradient(135deg, #FFD76E 0%, #FFC730 100%);
}

/* 通用卡片 */
.section-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 24rpx;
}

/* 分类列表 */
.category-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.category-item {
  display: flex;
  align-items: center;
}

.category-info {
  width: 180rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.category-name {
  font-size: 26rpx;
  color: #4B5563;
}

.category-count {
  font-size: 24rpx;
  color: #9CA3AF;
}

.category-bar-bg {
  flex: 1;
  height: 16rpx;
  background: #F3F4F6;
  border-radius: 8rpx;
  overflow: hidden;
  margin-left: 20rpx;
}

.category-bar {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

/* 本周阅读图表 */
.weekly-chart {
  padding: 20rpx 0;
}

.chart-bars {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 240rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-wrapper {
  height: 180rpx;
  display: flex;
  align-items: flex-end;
  margin-bottom: 12rpx;
}

.bar-fill {
  width: 32rpx;
  border-radius: 16rpx 16rpx 4rpx 4rpx;
  min-height: 8rpx;
  transition: height 0.5s ease;
}

.bar-label {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* 成就摘要 */
.achievement-summary {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.achievement-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #FFFBEB;
  border-radius: 20rpx;
}

.achievement-emoji {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.achievement-text {
  flex: 1;
}

.achievement-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1F2937;
  margin-bottom: 4rpx;
}

.achievement-status {
  font-size: 22rpx;
  color: #F59E0B;
}

/* 推荐列表 */
.recommend-desc {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 24rpx;
}

.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.recommend-book {
  display: flex;
  padding: 20rpx;
  background: #F9FAFB;
  border-radius: 24rpx;
}

.recommend-book .book-cover {
  width: 140rpx;
  height: 180rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.recommend-book .cover-emoji {
  font-size: 64rpx;
}

.recommend-book .book-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.book-tag {
  align-self: flex-start;
  padding: 6rpx 16rpx;
  background: #FEF3C7;
  color: #D97706;
  font-size: 20rpx;
  border-radius: 20rpx;
  margin-bottom: 8rpx;
}

.recommend-book .book-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.book-summary {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.5;
  flex: 1;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.read-btn {
  align-self: flex-start;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #FF9F43;
  font-weight: 500;
}

/* 热门推荐网格 */
.popular-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -12rpx;
}

.popular-book {
  width: 33.333%;
  padding: 12rpx;
  box-sizing: border-box;
}

.popular-cover {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.popular-emoji {
  font-size: 60rpx;
}

.popular-title {
  font-size: 24rpx;
  color: #4B5563;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
