/* pages/index/index.wxss */

.page {
  min-height: 100vh;
  background: #FFFBF0;
}

/* 头部区域 */
.header {
  position: relative;
  padding-bottom: 120rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 420rpx;
  background: linear-gradient(180deg, #FFF5E0 0%, #FFFBF0 100%);
  border-radius: 0 0 60rpx 60rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  padding: 40rpx 32rpx 0;
}

/* 问候区域 */
.greeting-section {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.mascot {
  width: 120rpx;
  height: 120rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 199, 48, 0.3);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.mascot-emoji {
  font-size: 64rpx;
}

.greeting-text {
  flex: 1;
}

.greeting-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.greeting-sub {
  font-size: 26rpx;
  color: #6B7280;
}

/* 用户卡片 */
.user-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #FFE8A3 0%, #FFD76E 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.avatar-emoji {
  font-size: 48rpx;
}

.user-detail {
  flex: 1;
}

.level-tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  background: linear-gradient(135deg, #FFD76E 0%, #FFC730 100%);
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background: #F3F4F6;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFD76E 0%, #FFC730 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.user-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #9CA3AF;
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: #E5E7EB;
}

/* 内容区域 */
.content {
  padding: 0 32rpx 120rpx;
  margin-top: -80rpx;
  position: relative;
  z-index: 2;
}

.section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #1F2937;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-more {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 推荐卡片 */
.recommend-card {
  position: relative;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
}

.recommend-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.6;
}

.recommend-content {
  position: relative;
  z-index: 1;
  display: flex;
  padding: 32rpx;
}

.recommend-cover {
  width: 160rpx;
  height: 220rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.cover-emoji {
  font-size: 80rpx;
}

.recommend-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.recommend-category {
  align-self: flex-start;
  margin-bottom: 12rpx;
}

.recommend-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 12rpx;
}

.recommend-desc {
  font-size: 24rpx;
  color: #4B5563;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.recommend-btn {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  padding: 14rpx 32rpx;
  background: #fff;
  color: #FF9F43;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 999rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 159, 67, 0.3);
}

.btn-arrow {
  margin-left: 8rpx;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  justify-content: space-between;
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.action-icon.camera {
  background: #F0F9FF;
}

.action-icon.trophy {
  background: #FFFBEB;
}

.action-icon.gift {
  background: #FDF2F8;
}

.action-icon.star {
  background: #F0FFF7;
}

.action-text {
  font-size: 24rpx;
  color: #4B5563;
}

/* 书籍滚动列表 */
.books-scroll {
  white-space: nowrap;
  margin: 0 -32rpx;
  padding: 0 32rpx;
}

.book-card {
  display: inline-block;
  width: 200rpx;
  margin-right: 24rpx;
  vertical-align: top;
}

.book-cover {
  width: 200rpx;
  height: 260rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.08);
}

.book-cover-emoji {
  font-size: 80rpx;
}

.book-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #1F2937;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-category {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* 勋章网格 */
.badges-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -12rpx;
}

.badge-item {
  width: 25%;
  padding: 12rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.badge-icon {
  width: 88rpx;
  height: 88rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 10rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.badge-item.unlocked .badge-icon {
  background: linear-gradient(135deg, #FFFBEB 0%, #FEF3C7 100%);
}

.badge-item.locked .badge-icon {
  filter: grayscale(100%);
  opacity: 0.4;
}

.badge-name {
  font-size: 22rpx;
  color: #6B7280;
  text-align: center;
}

.badge-item.unlocked .badge-name {
  color: #1F2937;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.float {
  animation: float 3s ease-in-out infinite;
}
